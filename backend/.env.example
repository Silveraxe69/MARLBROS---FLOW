# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/smart_bus_db

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:19006,http://localhost:8081

# JWT Secret Key
# In production, use a strong, random secret key
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Bus Simulation Settings (optional)
SIMULATION_INTERVAL=5000
UPDATE_INTERVAL=3000
