# Expo App Configuration
# Note: Expo uses app.json for extra configs
# This file is for documentation purposes

# Backend API Configuration
# IMPORTANT: Use your computer's IP address, NOT localhost
# Find your IP:
#   Windows: ipconfig
#   Mac/Linux: ifconfig
# 
# Example configurations:
# Development (local network):
API_URL=http://192.168.1.100:5000/api
SOCKET_URL=http://192.168.1.100:5000

# Mapbox Token (Optional)
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_access_token_here

# Note: To use these variables, add them to app.json under "extra" field:
# 
# "extra": {
#   "apiUrl": "http://YOUR_IP:5000/api",
#   "socketUrl": "http://YOUR_IP:5000",
#   "mapboxToken": "YOUR_MAPBOX_TOKEN"
# }
#
# Then access via: import Constants from 'expo-constants';
# const API_URL = Constants.expoConfig.extra.apiUrl;
